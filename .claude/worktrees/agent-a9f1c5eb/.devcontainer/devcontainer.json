{
  "name": "やさしい交換日記 - Claude Code",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // Claude Code を公式 devcontainer feature でインストール
  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
  },

  // ポート転送（Next.js + Supabase ローカル）
  "forwardPorts": [3000, 54321, 54322, 54323],
  "portsAttributes": {
    "3000": { "label": "Next.js Dev Server" },
    "54321": { "label": "Supabase API" },
    "54322": { "label": "Supabase DB" },
    "54323": { "label": "Supabase Studio" }
  },

  // 設定ディレクトリをボリュームに永続化
  // → コンテナを再ビルドしてもログイン状態が維持される
  "mounts": [
    // Claude Code の認証情報
    "source=yasashii-diary-claude-config-${devcontainerId},target=/home/node/.claude,type=volume",
    // GitHub CLI の認証情報（gh auth login を rebuild のたびに不要にする）
    "source=yasashii-diary-gh-config-${devcontainerId},target=/home/node/.config/gh,type=volume"
  ],

  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/node/.claude"
  },

  // このベースイメージの実ユーザーは node
  "containerUser": "node",

  // コンテナ起動後に依存パッケージをインストール
  "postCreateCommand": "npx supabase --version",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "Prisma.prisma",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.tsdk": "node_modules/typescript/lib"
      }
    }
  },

  // --dangerously-skip-permissions を安全に使うための設定
  // ファイアウォールでコンテナのネットワークを制限しているため有効
  "runArgs": ["--init"]
}
